# Google AI API key — get from https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# LlamaCloud API key — get from https://cloud.llamaindex.ai/api-key
LLAMA_CLOUD_API_KEY=your-llama-cloud-api-key-here

# AlloyDB password — set when creating the AlloyDB cluster
DB_PASS=your-alloydb-password-here

# AlloyDB instance URI — format: projects/PROJECT/locations/REGION/clusters/CLUSTER/instances/INSTANCE
ALLOYDB_INSTANCE_URI=projects/your-project/locations/us-central1/clusters/your-cluster/instances/your-instance

# GCP project ID — your Google Cloud project identifier
GCP_PROJECT_ID=your-gcp-project-id

# Log format — use "pretty" for local dev, omit for JSON in production
LOG_FORMAT=pretty
