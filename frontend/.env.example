# Backend API base URL
# For Vite projects, environment variables must be prefixed with VITE_ to be exposed to the client.
# Use VITE_API_BASE in your .env file:
VITE_API_BASE=http://localhost:8000

# Note: The spec references REACT_APP_API_BASE for CRA compatibility.
# In this Vite project, use VITE_API_BASE and access it via import.meta.env.VITE_API_BASE
# REACT_APP_API_BASE=http://localhost:8000
